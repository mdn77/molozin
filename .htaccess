# Молозин.ру - Конфигурация Apache

# ==========================================
# БЕЗОПАСНОСТЬ
# ==========================================

# Отключить отображение содержимого директорий
Options -Indexes

# Защита от просмотра .htaccess и других служебных файлов
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Защита конфигурационных и log файлов
<FilesMatch "\.(log|ini|conf|bak|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Защита от инъекций в URL
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Блокировка подозрительных паттернов в URL
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|[|%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|[|%[0-9A-Z]{0,2})
    RewriteRule ^(.*)$ - [F,L]
</IfModule>

# ==========================================
# ПРОИЗВОДИТЕЛЬНОСТЬ
# ==========================================

# Включить сжатие GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# Кэширование статических файлов
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Изображения
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS и JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Шрифты
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    
    # HTML
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Кэш-контроль
<IfModule mod_headers.c>
    # Статические ресурсы - долгое кэширование
    <FilesMatch "\.(ico|jpg|jpeg|png|gif|svg|webp|css|js|woff|woff2|ttf|otf)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # HTML - без кэширования
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
    
    # Безопасность заголовков
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (настройте под свои нужды)
    # Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://mc.yandex.ru; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://mc.yandex.ru;"
</IfModule>

# ==========================================
# ЧИСТЫЕ URL (без .html расширений)
# ==========================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Custom routes for privacy and terms
    RewriteRule ^privacy/?$ privacy.php [L]
    RewriteRule ^terms/?$ terms.php [L]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # Блог: ЧПУ
    # Список статей: /blog/
    RewriteRule ^blog/?$ blog.php [L,QSA]
    # Статья блога: /blog/{slug}/
    RewriteRule ^blog/([a-zA-Z0-9_-]+)/?$ blog.php?article=$1 [L,QSA]

    # PROG SEO ROUTING: /uslugi/slug -> index.php?seo_slug=slug
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^uslugi/([a-zA-Z0-9_-]+)/?$ index.php?seo_slug=$1 [L,QSA]
    
    # Удаление .html из URL
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.*)$ $1.html [L]
    
    # Редирект с www на без www (или наоборот, выберите нужное)
    # Вариант 1: БЕЗ www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
    
    # Вариант 2: С www (закомментирован)
    # RewriteCond %{HTTP_HOST} !^www\. [NC]
    # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]
    
    # Принудительный HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
    
    # Удаление trailing slash (необязательно)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [R=301,L]
</IfModule>

# ==========================================
# MIME TYPES
# ==========================================

<IfModule mod_mime.c>
    AddType application/javascript js
    AddType text/css css
    AddType image/webp webp
    AddType font/woff woff
    AddType font/woff2 woff2
    AddType font/ttf ttf
    AddType font/otf otf
</IfModule>

# ==========================================
# ОГРАНИЧЕНИЕ РАЗМЕРА ФАЙЛОВ
# ==========================================

# Увеличение лимитов для загрузки файлов (если нужно)
# php_value upload_max_filesize 50M
# php_value post_max_size 50M
# php_value max_execution_time 300
# php_value max_input_time 300

# ==========================================
# КОДИРОВКА
# ==========================================

AddDefaultCharset UTF-8

# ==========================================
# СТРАНИЦЫ ОШИБОК (создайте их при необходимости)
# ==========================================

# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html

# ==========================================
# БЛОКИРОВКА СПАМ-БОТОВ (опционально)
# ==========================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Блокировка известных спам-ботов
    RewriteCond %{HTTP_USER_AGENT} ^.*(SemrushBot|AhrefsBot|MJ12bot|DotBot).*$ [NC]
    RewriteRule ^.* - [F,L]
</IfModule>

# ==========================================
# �������������� ����������� ��������
# ==========================================

<IfModule mod_expires.c>
    # �������������� ������� ��� WebP
    ExpiresByType image/webp "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # ���������� ETags ��� ��������� ������ ����
    Header unset ETag
</IfModule>
FileETag None

